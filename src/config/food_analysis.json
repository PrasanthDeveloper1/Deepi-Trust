{
  "version": "2.0.0",
  "engine": "Deepi Trust Food Vision Engine",
  "description": "Client-side food detection and quality analysis using color spectrum analysis, pattern recognition, and configurable scoring rubrics. No external API keys required.",

  "detection": {
    "weights": {
      "food_color": 0.70,
      "saturation": 0.50,
      "diversity": 0.30,
      "brightness_penalty": -0.25,
      "gray_penalty": -0.40
    },
    "thresholds": {
      "food_color_minimum": 0.22,
      "food_confidence_minimum": 0.42,
      "min_saturation": 0.10,
      "min_color_diversity": 2
    },
    "non_food": {
      "document_gray_threshold": 0.55,
      "document_saturation_max": 0.10,
      "sky_blue_threshold": 0.35,
      "dark_image_threshold": 0.50,
      "bright_image_threshold": 0.55,
      "skin_tone_dominant_threshold": 0.45,
      "uniform_color_threshold": 0.70
    }
  },

  "quality_scoring": {
    "freshness": { "min": 55, "max": 98, "weight": 0.30 },
    "packaging": { "min": 58, "max": 95, "weight": 0.15 },
    "hygiene":   { "min": 55, "max": 97, "weight": 0.25 },
    "temperature": { "min": 56, "max": 96, "weight": 0.15 },
    "contamination": { "min": 58, "max": 98, "weight": 0.15 }
  },

  "quality_notes": {
    "freshness": {
      "excellent": "Vibrant, saturated colors indicate very fresh food",
      "good": "Colors appear fresh and well-maintained",
      "fair": "Moderate freshness — some color dulling noted",
      "poor": "Significant color degradation suggests staleness"
    },
    "packaging": {
      "excellent": "Well-organized, clean container presentation",
      "good": "Adequate packaging and containment visible",
      "fair": "Basic containment — could be improved",
      "poor": "Poor packaging — food appears exposed"
    },
    "hygiene": {
      "excellent": "Clean preparation environment clearly evident",
      "good": "Reasonable cleanliness maintained throughout",
      "fair": "Minor cleanliness concerns noted",
      "poor": "Significant hygiene concerns visible"
    },
    "temperature": {
      "excellent": "Warm tones suggest proper serving temperature",
      "good": "Temperature indicators appear acceptable",
      "fair": "Temperature conditions may not be optimal",
      "poor": "Food appears cold or improperly stored"
    },
    "contamination": {
      "excellent": "No contamination indicators detected",
      "good": "Very low contamination risk observed",
      "fair": "Minor anomalies noted — low risk",
      "poor": "Potential contamination signs detected"
    }
  },

